@page "/admin/api-keys"
@model YobaConf.Web.Pages.Admin.ApiKeysModel
@{
	ViewData["Title"] = "API keys";
}

<div class="mb-4 text-sm">
	<a href="/" class="link opacity-70 hover:opacity-100" data-testid="back-to-index">← Home</a>
</div>

<h1 class="text-xl font-semibold mb-4" data-testid="api-keys-title">API keys</h1>

@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
	<div class="alert alert-error mb-3" data-testid="api-keys-error">@Model.ErrorMessage</div>
}
@if (!string.IsNullOrEmpty(Model.NewlyCreatedToken))
{
	<div class="alert alert-warning mb-3" data-testid="api-keys-plaintext-alert">
		<div class="flex flex-col gap-2 w-full">
			<span><strong>Save this token now — it will not be shown again.</strong></span>
			<div class="flex items-start gap-2">
				<code class="font-mono text-sm break-all flex-1" data-testid="api-keys-plaintext">@Model.NewlyCreatedToken</code>
				<button type="button" class="btn btn-xs btn-ghost" data-testid="api-keys-copy-token" data-token="@Model.NewlyCreatedToken" aria-label="Copy token">Copy</button>
			</div>
			<span class="text-xs opacity-0" data-testid="api-keys-copy-feedback" aria-live="polite"></span>
		</div>
	</div>
}

<section class="mb-6">
	<h2 class="text-sm uppercase opacity-70 mb-2">Create key</h2>
	<form method="post" asp-page-handler="Create" autocomplete="off" class="grid grid-cols-1 gap-3" data-testid="api-keys-create-form">
		<label class="form-control">
			<span class="label-text">Description</span>
			<input type="text" name="description" required
				class="input input-bordered input-sm"
				data-testid="api-keys-create-description" />
		</label>
		<label class="form-control">
			<span class="label-text">Required tags (one <code class="font-mono text-xs">key=value</code> per line)</span>
			<textarea name="requiredTags" rows="3"
				class="textarea textarea-bordered font-mono text-xs"
				placeholder="env=prod&#10;project=yobapub"
				data-testid="api-keys-create-required-tags"></textarea>
		</label>
		<label class="form-control">
			<span class="label-text">Allowed key prefixes (one per line, optional)</span>
			<textarea name="allowedPrefixes" rows="3"
				class="textarea textarea-bordered font-mono text-xs"
				placeholder="db.&#10;cache."
				data-testid="api-keys-create-allowed-prefixes"></textarea>
		</label>
		<div>
			<button type="submit" class="btn btn-sm btn-primary" data-testid="api-keys-create-submit">Create</button>
		</div>
	</form>
</section>

<section>
	<h2 class="text-sm uppercase opacity-70 mb-2">Active keys (@Model.Keys.Count)</h2>
	@if (Model.Keys.Count == 0)
	{
		<div class="text-xs opacity-60 italic" data-testid="api-keys-empty">No API keys yet.</div>
	}
	else
	{
		<div class="border border-base-300 rounded divide-y divide-base-300" data-testid="api-keys-list">
			@foreach (var k in Model.Keys)
			{
				<div class="flex items-center gap-3 p-2" data-testid="api-keys-row" data-key-id="@k.Id">
					<span class="font-mono text-xs text-primary" data-testid="api-keys-prefix">@k.TokenPrefix…</span>
					<span class="text-xs flex-1" data-testid="api-keys-description">@k.Description</span>
					<span class="font-mono text-xs opacity-60" data-testid="api-keys-required-tags">@k.RequiredTags.CanonicalJson</span>
					<form method="post" asp-page-handler="Delete" class="inline"
						onsubmit="return confirm('Delete key @k.TokenPrefix… (@k.Description)?');">
						<input type="hidden" name="id" value="@k.Id" />
						<button type="submit" class="btn btn-xs btn-ghost text-error" data-testid="api-keys-delete">Delete</button>
					</form>
				</div>
			}
		</div>
	}
</section>
