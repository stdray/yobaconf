<!DOCTYPE html>
<html lang="en" data-theme="dark" class="h-full">
<head>
	<meta charset="utf-8" />
	<meta name="viewport" content="width=device-width, initial-scale=1.0" />
	<title>@ViewData["Title"] - YobaConf</title>
	<link rel="stylesheet" href="~/css/app.css" asp-append-version="true" />
	<script src="https://unpkg.com/htmx.org@2.0.4" integrity="sha384-HGfztofotfshcF7+8n44JQL2oJmowVChPTg48S+jvZoztPfvwD79OC/LTtG6dMp+" crossorigin="anonymous"></script>
	<!-- Prism.js JSON highlighting for the resolve-preview panel. HOCON component comes in a
	     follow-up commit (port of sabieber/vscode-hocon TextMate grammar). -->
	<link rel="stylesheet" href="https://unpkg.com/prismjs@1.29.0/themes/prism-tomorrow.css" />
	<script src="https://unpkg.com/prismjs@1.29.0/components/prism-core.min.js"></script>
	<script src="https://unpkg.com/prismjs@1.29.0/components/prism-json.min.js"></script>
	<script type="module" src="~/js/admin.js" asp-append-version="true"></script>
</head>
<body class="min-h-full">
	<div class="navbar bg-base-200 border-b border-base-300">
		<div class="mx-auto max-w-6xl w-full px-4 flex gap-6 items-center">
			<a class="text-lg font-semibold" asp-page="/Index" data-testid="nav-home">YobaConf</a>
			@if (User.Identity?.IsAuthenticated == true)
			{
				<a class="text-sm opacity-70 hover:opacity-100" asp-page="/Index" data-testid="nav-configs">Configs</a>
				<a class="text-sm opacity-70 hover:opacity-100" asp-page="/Import" data-testid="nav-import">New from paste</a>
				<form method="post" action="/Logout" class="ml-auto flex items-center gap-3">
					<span class="text-sm opacity-70" data-testid="nav-username">@User.Identity.Name</span>
					<button type="submit" data-testid="logout-submit" class="btn btn-xs btn-ghost">Sign out</button>
				</form>
			}
		</div>
	</div>
	<main class="mx-auto max-w-6xl px-4 py-6">
		@RenderBody()
	</main>
	@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
