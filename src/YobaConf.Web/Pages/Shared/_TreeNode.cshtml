@using YobaConf.Web.Pages
@model TreeNodeContext

@{
	var indent = Model.Depth;
	var style = $"padding-left: {8 + indent * 20}px;";
}

@foreach (var node in Model.Nodes)
{
	var isActual = !node.IsVirtual && node.Path is not null;
	var glyph = node.IsVirtual ? "○" : "●";
	var glyphClass = isActual ? "text-primary" : "opacity-50";
	var dbPath = node.Path?.ToDbPath() ?? BuildVirtualPath(node);
	var hasChildren = node.Children.Count > 0;
	// Virtual dirs are clickable too — /Node?path=X renders the fallthrough notice
	// with a "Create here" affordance. Users have one obvious way to "fill in" a
	// missing intermediate path.
	var urlPath = node.Path?.ToUrlPath() ?? dbPath.Replace('/', '.');

	<li class="border-b border-dotted border-base-300" data-path="@dbPath" data-match="1">
		<a asp-page="/Node" asp-route-path="@urlPath"
			class="flex items-center gap-2 py-1 rounded-none@(isActual ? "" : " opacity-70")"
			style="@style"
			data-testid="node-link">
			<span class="font-mono text-xs @glyphClass">@glyph</span>
			<span class="font-mono text-sm">@node.Segment</span>
			@if (!isActual)
			{
				<span class="text-xs opacity-60 ml-auto pr-3">virtual dir · click to create</span>
			}
		</a>
		@if (hasChildren)
		{
			<ul class="list-none p-0 m-0">
				@await Html.PartialAsync("_TreeNode", new TreeNodeContext(node.Children, Model.Depth + 1))
			</ul>
		}
	</li>
}

@functions {
	static string BuildVirtualPath(TreeNode self)
	{
		// Virtual nodes don't carry the canonical path — reconstruct from the first
		// actual descendant. Used only for the data-path attribute (search filter).
		TreeNode? firstActual = null;
		foreach (var c in self.Children)
		{
			firstActual = FindFirstActual(c);
			if (firstActual is not null) break;
		}
		if (firstActual?.Path is { } p)
		{
			var segments = p.ToDbPath().Split('/');
			// Virtual path = one level above firstActual; approximate by joining siblings'
			// segment back-stack. Simpler: use all-but-last of the first actual's path.
			return string.Join("/", segments.Take(segments.Length - 1));
		}
		return self.Segment;
	}

	static TreeNode? FindFirstActual(TreeNode n)
	{
		if (!n.IsVirtual && n.Path is not null) return n;
		foreach (var c in n.Children)
		{
			var f = FindFirstActual(c);
			if (f is not null) return f;
		}
		return null;
	}
}
