@page
@model YobaConf.Web.Pages.IndexModel
@{
	ViewData["Title"] = "Configs";
}

<h1 class="text-2xl font-semibold mb-4">Configs</h1>

@if (Model.Paths.Count == 0)
{
	<p class="opacity-70">
		No nodes yet.
		<a asp-page="/Import" class="link link-primary" data-testid="import-empty-cta">Import from JSON / YAML / .env</a>
		to get started.
	</p>
}
else
{
	<ul class="menu bg-base-200 rounded-box border border-base-300 w-full" data-testid="node-list">
		@foreach (var path in Model.Paths)
		{
			<li>
				<a asp-page="/Node" asp-route-path="@path.ToUrlPath()"
					data-testid="node-link"
					data-path="@path.ToDbPath()"
					class="font-mono text-sm">@path.ToDbPath()</a>
			</li>
		}
	</ul>
}
