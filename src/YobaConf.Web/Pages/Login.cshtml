@page
@model LoginModel
@{
	ViewData["Title"] = "Sign in";
	Layout = null;
}
<!DOCTYPE html>
<html lang="en" data-theme="dark" class="h-full">
<head>
	<meta charset="utf-8" />
	<meta name="viewport" content="width=device-width, initial-scale=1.0" />
	<title>Sign in - YobaConf</title>
	<link rel="stylesheet" href="~/css/app.css" asp-append-version="true" />
</head>
<body class="min-h-full flex items-center justify-center bg-base-300">
	<form method="post" id="login-form" autocomplete="on" class="card w-96 bg-base-200 p-6 shadow-xl">
		<h1 class="text-xl font-semibold mb-4">Sign in to YobaConf</h1>

		@if (!string.IsNullOrEmpty(Model.ErrorMessage))
		{
			<div class="alert alert-error mb-4" data-testid="login-error">@Model.ErrorMessage</div>
		}

		<input type="hidden" name="returnUrl" value="@Model.ReturnUrl" />

		<div class="form-control mb-3">
			<label for="login-username" class="label-text">Username</label>
			<input type="text" id="login-username" name="username" required autocomplete="username"
				class="input input-bordered" data-testid="login-username" value="@Model.Username" />
		</div>

		<div class="form-control mb-4">
			<label for="login-password" class="label-text">Password</label>
			<input type="password" id="login-password" name="password" required autocomplete="current-password"
				class="input input-bordered" data-testid="login-password" />
		</div>

		<button type="submit" class="btn btn-primary" data-testid="login-submit">Sign in</button>
	</form>
</body>
</html>
